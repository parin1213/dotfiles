{{- $p := includeTemplate "profile" . | fromJson -}}
# =============================================================================
# Ghostty Config - Migrated from iTerm2
# =============================================================================

# --- Font ---
font-family = HackGen Console NF
font-style = Bold
font-style-bold = Bold
font-style-italic = Bold
font-style-bold-italic = Bold
# font-size の値は .chezmoidata.toml の envs.<env>.ghostty_font_size。判断軸:
#   同じ pt でも見かけは「論理解像度 = パネル解像度 ÷ OS スケーリング」で決まる。
#   高PPIノート(Surface Go3: 220PPI→GNOME 1.5→論理1280×853)は 24pt だと行数が半減して
#   大きすぎる → 16pt。低PPI大画面(LG 49"TV: ~91PPI→100%→論理3072×1728)は 24pt が適正。
#   新マシンは PPI×スケーリングから論理解像度を出し、行数が TV(24pt) 並みになる pt を選ぶ。
font-size = {{ $p.ghostty_font_size }}
# iTerm2の "Thin Strokes" = 3 相当
font-thicken = true

# --- Background Image ---
background-image = ~/Pictures/sakura.jpg
background-image-fit = cover
background-image-opacity = 0.25

# --- Window / UX ---
# Alt+←→ などで単語移動を効かせる（macOSのOptionをAltとして送出）
macos-option-as-alt = true
# 選択しただけでコピー（右クリックでペースト）
copy-on-select = true
# 余白で視認性アップ
window-padding-x = 8
window-padding-y = 6
# カーソル
cursor-style = bar
cursor-style-blink = false
# 閉じる時の確認をオフ
confirm-close-surface = false
# ウィンドウ状態の復元
window-save-state = always

# --- Shell Integration ---
# zsh のコマンド境界/所要時間/タイトル等を Ghostty に伝える
# コマンド出力のスクロール・ジャンプ等が快適になる
shell-integration = zsh
shell-integration-features = cursor,sudo,title

# --- zellij 自動起動 & タブ統合 ---
# ① ローカル端末起動時に単一 "main" セッションへ自動アタッチ（無ければ作成）。
#    login shell 経由で起動し mise(shim) を PATH に乗せる（直接 exec だと mise activate 前で
#    zellij が PATH に無い）。-f は resurrect 時の "Press ENTER to run" 待ちをスキップ。
#    SSH 先は接続先 .zshrc 側で自動アタッチ済みなので、これはローカル GUI 端末専用。
command = zsh -l -c "zellij attach -c -f main"
# ② 端末の「新タブ」を OS タブではなく zellij の新タブにする。新タブキーに Alt+t(ESC t) を
#    送出し、zellij 側の `bind "Alt t" { NewTab }` を叩く。1ウィンドウ=1クライアントを保つ。
{{- if eq $p.os "darwin" }}
keybind = cmd+t=text:\x1bt
{{- else }}
keybind = ctrl+shift+t=text:\x1bt
{{- end }}
