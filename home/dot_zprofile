
# XDG 標準のユーザー bin。無ければ作る（安心設計）。元は pipx が自動追記した行。
mkdir -p "$HOME/.local/bin"
export PATH="$PATH:$HOME/.local/bin"
# mise を login shell で有効化（主に非対話ログイン用。対話では common.sh も担保）。
# この時点では PATH 構築前なので、mise の実体を順に探す（Linux=~/.local/bin / mac=brew）。
if command -v mise >/dev/null 2>&1; then
  eval "$(mise activate zsh)"
elif [ -x "$HOME/.local/bin/mise" ]; then
  eval "$("$HOME/.local/bin/mise" activate zsh)"
elif [ -x /opt/homebrew/bin/mise ]; then
  eval "$(/opt/homebrew/bin/mise activate zsh)"
fi

# auto_updates 付き cask（AltTab 等）はアプリ自身が更新するので brew の upgrade 対象から外す。
# 対象に入れると既存 .app と衝突して毎回エラー＋巻き戻しになり、ログがうるさいだけなので抑止する。
export HOMEBREW_NO_UPGRADE_AUTO_UPDATES_CASKS=1